#build-web params
OC_USER_ID=$(OC_USER_ID)
NAME=$(HOST_PREFIX)
BUILD_NAMESPACE=$(BUILD_NAMESPACE)
IMAGE_TAG=$(BUILD_TAG)
REPO_NAME=$(SOURCE_REPOSITORY_REF)
REPO_BRANCH=$(SOURCE_REPOSITORY_BRANCH)

#deploy-web params
LABEL_NAME=$(LABEL_NAME)
IMAGE_TAG=$(BUILD_TAG)
NAMESPACE=$(NAMESPACE)

#build-patroni params
NAME=tbtb-yeaf-patroni
TAG="12-latest"
BASE_IMAGE_NAME=postgres
BASE_IMAGE_TAG="12"
SOURCE_REPOSITORY_REF="master"
SOURCE_CONTEXT_DIR="apps/pgsql/patroni/docker"

#deploy-patroni params
IMAGE_STREAM_TAG=patroni:12-latest

#db-backup-build-postgresql params
BACKUP_POSTGRESQL_APP_NAME=$(BACKUP_POSTGRESQL_APP_NAME)
OUTPUT_IMAGE_TAG=v1
BASE_IMAGE_FOR_BUILD=artifacts.developer.gov.bc.ca/docker-remote/centos/postgresql-12-centos7:20200917-804ef01

#db-backup-deploy-postgresql params
IMAGE_NAMESPACE=$(BUILD_NAMESPACE)
SOURCE_IMAGE_NAME=$(BACKUP_POSTGRESQL_APP_NAME)
TAG_NAME=v1
FTP_SECRET_KEY=$(BACKUP_POSTGRESQL_APP_NAME)-ftp-secret
BACKUP_VOLUME_NAME=$(BACKUP_POSTGRESQL_APP_NAME)-pvc
BACKUP_VOLUME_SIZE=20Gi
VERIFICATION_VOLUME_SIZE=5Gi
ENVIRONMENT_NAME=$(NAMESPACE)
CONFIG_MAP_NAME=$(BACKUP_CONFIGMAP_NAME)
VERIFICATION_VOLUME_NAME=$(BACKUP_POSTGRESQL_APP_NAME)-verification-pvc
DATABASE_SERVER_NAME=PATRONI_MASTER
DATABASE_SECRET_NAME=patroni-creds
DATABASE_SECRET_USER_KEY_NAME=superuser-username
DATABASE_SECRET_PASSWORD_KEY_NAME=superuser-password
ENVIRONMENT_FRIENDLY_NAME='$(NAMESPACE) POSTGRESQL DB Backups'
